PORT=4001
JWT_SECRET=sgi_auditoria_secret_cambiar
CORS_ORIGIN=http://localhost:5173
DB_PATH=./data/sgi-auditoria.sqlite

# auto: usa Odoo si las variables ODOO_* estan completas. Si no, usa mock.
# Para forzar Odoo: ERP_PROVIDER=odoo
ERP_PROVIDER=auto

ODOO_DB_HOST=
ODOO_DB_PORT=5432
ODOO_DB_NAME=
ODOO_DB_USER=
ODOO_DB_PASSWORD=
ODOO_DB_SSL=false

# IA opcional
AI_ENABLED=false
AI_PROVIDER=ollama-local
AI_MODEL=llama3.1:8b
OLLAMA_URL=http://localhost:11434
# Para Ollama Cloud usar AI_PROVIDER=ollama-cloud y pegar una clave nueva en AI_API_KEY
AI_API_KEY=
OLLAMA_CLOUD_URL=https://ollama.com
